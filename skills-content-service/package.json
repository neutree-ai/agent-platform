{
  "name": "@neutree-ai/skills-content-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --target=node22 --outfile=dist/index.js --packages=external --sourcemap",
    "start": "node dist/index.js",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-openapi": "^1.2.4",
    "@scalar/hono-api-reference": "^0.10.7",
    "hono": "^4.7.0",
    "pg": "^8.21.0",
    "tar-stream": "^3.2.0",
    "tsx": "^4.21.0",
    "undici": "^7.25.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/tar-stream": "^3.1.4",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.7"
  }
}
