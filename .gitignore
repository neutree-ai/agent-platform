# Secrets - never commit
k8s/secrets.yaml
postgres/k8s/secret.yaml
k8s/*kubeconfig*
.env*

# Self-host deployment (secrets, rendered output, runtime artifacts)
self-host/values.env
self-host/kubeconfig.yaml
self-host/rendered/
self-host/prereqs/
self-host/offline/tos-images.tar.gz

# OS
.DS_Store

# Build artifacts
node_modules/
agents/*/workspace/
dist
*.sqlite
*.tsbuildinfo

tmp

.claude

# Pre-built excalidraw assets (fonts, CSS, JS bundle)
