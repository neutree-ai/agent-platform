exports[`buildDeploymentSpec golden master > minimal: afs off, memory off, no nodeselector/pullsecret/resources 1`] = `
{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "annotations": {
      "agent-platform/workspace-version": "6",
    },
    "labels": {
      "app": "nap",
