{
  "name": "@neutree-ai/control-plane",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "build": "esbuild src/index.ts scripts/seed-admin.ts scripts/seed-mcp-catalog-core.ts scripts/seed-oauth-clients.ts --bundle --format=esm --platform=node --target=node22 --outdir=dist --packages=external --sourcemap --entry-names=[name]",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip"
  },
  "dependencies": {
    "@datadog/pprof": "^5.14.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@hono/node-server": "^1.19.14",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-openapi": "^1.2.4",
    "@kubernetes/client-node": "0.22.3",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@node-rs/argon2": "^2.0.2",
    "@scalar/hono-api-reference": "^0.10.7",
    "croner": "^9.1.0",
    "hono": "^4.7.0",
    "ldapts": "^8.1.4",
    "multiplex": "^6.7.0",
    "pg": "^8.13.0",
    "pg-boss": "^12.14.0",
    "prom-client": "^15.1.3",
    "tsx": "^4.21.0",
    "undici": "^7.25.0",
    "ws": "^8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "knip": "^6.0.6",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
