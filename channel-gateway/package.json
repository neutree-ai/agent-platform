{
	"name": "@neutree-ai/channel-gateway",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "node --env-file=.env --import tsx --watch src/index.ts",
		"build": "esbuild src/index.ts --bundle --format=esm --platform=node --target=node22 --outfile=dist/index.js --packages=external --sourcemap",
		"start": "node dist/index.js",
		"lint": "biome check .",
		"lint:fix": "biome check --write ."
	},
	"dependencies": {
		"@aws-sdk/client-sqs": "^3.750.0",
		"@hono/node-server": "^1.19.14",
		"@slack/socket-mode": "^2.0.3",
		"@slack/web-api": "^7.9.1",
		"hono": "^4.7.0",
		"p-map": "^7.0.4",
		"pg": "^8.13.0",
		"tsx": "^4.21.0",
		"ws": "^8.18.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.11.0",
		"@types/ws": "^8.5.13",
		"esbuild": "^0.28.0",
		"typescript": "^6.0.2"
	}
}
