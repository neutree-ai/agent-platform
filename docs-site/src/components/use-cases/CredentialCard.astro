---
interface Props {
  name: string
  kind?: 'env' | 'file' | 'ssh'
  example?: string
  description: string
}

const { name, kind = 'env', example, description } = Astro.props
---

<article class="cred-card">
  <div class="cred-card__head">
    <span class={`cred-card__kind cred-card__kind--${kind}`}>{kind}</span>
    <code class="cred-card__name">{name}</code>
    {example && <span class="cred-card__sep">=</span>}
    {example && <code class="cred-card__example">{example}</code>}
  </div>
  <p class="cred-card__desc">{description}</p>
</article>

<style>
  .cred-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.6rem 0.85rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
  }

  .cred-card__head {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
    flex-wrap: wrap;
    font-size: 0.85rem;
  }

  .cred-card__kind {
    display: inline-flex;
    align-items: center;
    padding: 0.05rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--sl-color-accent-high);
    background: var(--sl-color-accent-low);
  }

  .cred-card__name {
    font-size: 0.9rem;
    font-weight: 600;
    background: transparent;
    padding: 0;
    color: var(--sl-color-white);
  }

  .cred-card__sep {
    color: var(--sl-color-gray-4);
  }

  .cred-card__example {
    background: var(--sl-color-gray-6);
    padding: 0.05rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.8rem;
    color: var(--sl-color-gray-2);
  }

  .cred-card__desc {
    margin: 0;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2);
  }
</style>
