# ============================================================================
# Neutree Agent Platform — Self-Hosted Deployment Configuration (CONNECTED)
# ============================================================================
# Copy this file to values.env and fill in the required values.
#
# This is the connected / online deployment: the cluster pulls images directly
# from the public registry. No offline bundle, no in-cluster registry.
#
# All optional modules default to OFF — set the *_ENABLED toggle to "true" to
# enable each one.

# --- Container Registry -----------------------------------------------------
# Public registry path under which all first-party service images live as
# sub-paths, e.g. ${REGISTRY}/nap-cp:${IMAGE_TAG}. Default is the official
# public registry; override only if you mirror the images elsewhere.
REGISTRY=ghcr.io/neutree-ai/agent-platform
# Tag applied to every first-party image. Default "latest"; pin to a release
# tag (e.g. v4.2.0) for a reproducible install.
IMAGE_TAG=latest

# --- Advanced: naming & third-party images ----------------------------------
# These have sane defaults for a connected install — leave them commented out
# unless you are rebranding the deployment or mirroring third-party images into
# your own registry (e.g. an air-gapped site).
#
# Prefix on every first-party k8s object name and image sub-path. Pin this to
# keep object names stable across a rebrand; an existing install must NOT change
# it (it would rebuild every Deployment/Service/PVC under new names).
# APP_PREFIX=nap
# Application database created in postgres.
# DB_NAME=nap
#
# Third-party images. Default to their public upstreams; point each at a
# ${REGISTRY}/... path to pull everything from one mirror instead.
# POSTGRES_IMAGE=ghcr.io/cloudnative-pg/postgresql:16
# GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:8
# COTURN_IMAGE=docker.io/coturn/coturn:4.6
# NFS_SERVER_IMAGE=ghcr.io/obeone/nfs-server:2.2.3
# RUNTIME_NODE_IMAGE=docker.io/library/node:22-bookworm
# RUNTIME_PYTHON_IMAGE=docker.io/library/python:3.12-bookworm
# RUNTIME_GOLANG_IMAGE=docker.io/library/golang:1.23
# PAUSE_IMAGE=registry.k8s.io/pause:3.9

# --- Cluster & Access -------------------------------------------------------
NAMESPACE=nap
KUBECONFIG=./kubeconfig.yaml
TOS_HOST=10.0.0.100
TOS_NODE_PORT=30080

# How nap-cp / nap-browser / nap-sandbox are exposed to users.
#   nodeport  (default) — Service type NodePort, *_NODE_PORT applied
#   external             — Service type ClusterIP, customer's own ingress
#                          fronts these HTTP services.
# TURN/coturn always stays on hostPort UDP regardless of this setting.
INGRESS_MODE=nodeport

# --- Admin Account ----------------------------------------------------------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-min-6-chars
ADMIN_DISPLAY_NAME=Admin
# Session token signing key. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
# Credential encryption key (AES-256). Generate with: openssl rand -hex 32
CREDENTIAL_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32

# --- PostgreSQL (CloudNativePG) ---------------------------------------------
PG_USERNAME=nap
PG_PASSWORD=change-me-to-a-strong-password
PG_INSTANCES=3
PG_STORAGE_SIZE=10Gi
# StorageClass for PostgreSQL volumes (any CSI that supports ReadWriteOnce)
PG_STORAGE_CLASS=

# --- Shared Storage ---------------------------------------------------------
NFS_SERVER=10.0.0.200
NFS_PATH=/data/nap
# StorageClass for the NFS provisioner (ReadWriteMany; used by AFS)
NFS_STORAGE_CLASS=nfs-nap
# Size of the AFS RWX PVC. Resize later via kubectl edit pvc if the
# underlying StorageClass supports volume expansion.
AFS_STORAGE_SIZE=500Gi

# --- Agent Runtime ----------------------------------------------------------
# Prefix for dynamically spawned agent pods
AGENT_IMAGE_PREFIX=${REGISTRY}/nap-agent
AGENT_IMAGE_TAG=latest
# StorageClass for agent workspace PVCs (ReadWriteOnce is fine)
AGENT_STORAGE_CLASS=nfs-csi
# Node selector for agent pods. Format: key1=val1,key2=val2 (empty = any node)
AGENT_NODE_SELECTOR=

# ============================================================================
# Optional modules
# ============================================================================

# --- Code Sandbox ------------------------------------------------------------
# Lets agents run code and serve temporary web previews.
SANDBOX_ENABLED=false
SANDBOX_NODE_PORT=30086
SANDBOX_JWT_SECRET=
SANDBOX_SERVICE_KEY=
# Optional. Requires wildcard DNS *.<domain> → cluster nodes for subdomain preview.
SANDBOX_DOMAIN=
# Node selector for sandbox pods. Format: key1=val1,key2=val2 (empty = any node)
SANDBOX_NODE_SELECTOR=
# Public URL users reach sandbox at (no trailing slash). Set this when your own
# ingress / a custom domain fronts the service (e.g. INGRESS_MODE=external).
# Drives both the service's OAuth callback and the registered redirect_uri, so
# they stay in sync. Leave blank to derive http://${TOS_HOST}:${SANDBOX_NODE_PORT}.
SANDBOX_PUBLIC_URL=
# In-cluster URL of the OpenSandbox server (only used when SANDBOX_ENABLED=true).
# OpenSandbox is a separate, third-party component you install yourself — see
# README "Enabling Code Sandbox". Leave blank to default to the server svc in
# this namespace; set it if you install OpenSandbox into its own namespace, e.g.
# http://opensandbox-server.opensandbox-system.svc:80
OPENSANDBOX_URL=

# --- Remote Browser + TURN Relay --------------------------------------------
# Lets agents drive a real browser; the user sees it live via WebRTC.
# Setting BROWSER_ENABLED=true also turns on the bundled TURN relay (coturn).
BROWSER_ENABLED=false
BROWSER_NODE_PORT=30085
BROWSER_JWT_SECRET=
# Public LAN / WAN IP that browsers reach TURN at (required when BROWSER_ENABLED=true).
# Kubelet auto-detect is unreliable on multi-NIC nodes — set this explicitly.
TURN_HOST=
TURN_PORT=3478
TURN_AUTH_SECRET=
# Pin coturn to a specific node (recommended — TURN_HOST is the node IP).
# Format: key1=val1,key2=val2 (empty = scheduler picks any worker).
COTURN_NODE_SELECTOR=
# Public URL users reach the browser service at (no trailing slash). Same
# override semantics as SANDBOX_PUBLIC_URL — set when external ingress / a
# custom domain fronts it. Blank derives http://${TOS_HOST}:${BROWSER_NODE_PORT}.
BROWSER_PUBLIC_URL=

# --- LDAP -------------------------------------------------------------------
# Let users sign in with their LDAP account.
LDAP_ENABLED=false
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_SEARCH_BASE=
# Schema overrides — leave blank to use defaults shown in brackets.
# Override when your LDAP doesn't match the default inetOrgPerson layout.
LDAP_SEARCH_FILTER=          # [ (objectClass=inetOrgPerson) ]
LDAP_ATTR_USERNAME=          # [ sn ]  attribute matched against the login name
LDAP_ATTR_NAME=              # [ cn ]  display name shown in the UI
LDAP_ATTR_EMAIL=             # [ mail ]
