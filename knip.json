{
  "workspaces": {
    "control-plane": {
      "entry": ["scripts/*.ts", "src/services/db/mcp-catalog.ts"],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.ts"],
      "ignoreDependencies": ["tsx"]
    },
    "web": {
      "entry": [
        "src/components/ui/**/*.{ts,tsx}",
        "src/components/workspace/file-preview/extend/**/*.{ts,tsx}",
        "src/**/*.test.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx,mdx}"],
      "ignoreDependencies": ["@neutree-ai/theme"]
    },
    "browser-service": {
      "project": ["src/**/*.ts"]
    },
    "channel-gateway": {
      "project": ["src/**/*.ts"]
    },
    "sandbox-service": {
      "project": ["src/**/*.ts"]
    },
    "scheduler": {
      "project": ["src/**/*.ts"]
    },
    "env-runner-k8s": {
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@kubernetes/client-node"]
    },
    "skills-content-service": {
      "project": ["src/**/*.ts"]
    },
    "docs-site": {
      "entry": [
        "src/pages/**/*.{ts,astro}",
        "src/content/**/*.{md,mdx}",
        "src/components/**/*.{astro,ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx,astro}"]
    }
  },
  "ignore": [
    "agents/**",
    "internal/**",
    "packages/**"
  ],
  "ignoreBinaries": ["wait", "tsc"]
}
